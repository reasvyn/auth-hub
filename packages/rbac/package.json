{
  "name": "@reasvyn/auth-rbac",
  "version": "0.1.0",
  "description": "Role-Based Access Control (RBAC) engine for Auth-TS — with permission inheritance, wildcards, and multi-app scoping",
  "keywords": [
    "auth",
    "rbac",
    "permissions",
    "roles",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/express.mjs",
      "require": "./dist/middleware/express.js",
      "types": "./dist/middleware/express.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "clean": "rm -rf dist"
  },
  "dependencies": {},
  "peerDependencies": {
    "express": ">=4.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.3",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "*",
    "express": "^4.21.2",
    "react": "^18.3.1"
  }
}
